# Choose one of the following modes (PMTiles preferred for static hosting)
# PMTiles (static file served by Vite/Pages)
VITE_PM_TILES_URL=/tiles/step3_index.pmtiles

# Or Martin TileJSON (local/server)
# VITE_TILEJSON_SEGMENT=http://localhost:3001/step3_index.json
# VITE_TILEJSON_CARREAU200=http://localhost:3001/carreau200.json
# VITE_TILEJSON_ZONETRAFIC=http://localhost:3001/zone_trafic.json

# Source layer name produced by tippecanoe
VITE_WALK_SOURCE_LAYER=walknet
VITE_SEG_SOURCE_LAYER=walknet
VITE_CAR_SOURCE_LAYER=carreau200
VITE_ZT_SOURCE_LAYER=zone_trafic
